# Flask
SECRET_KEY=your-very-secret-key-change-this

# Supabase DB credentials — from Supabase > Project Settings > Database
user=postgres.your-project-ref
password=your-db-password
host=aws-0-your-region.pooler.supabase.com
port=6543
dbname=postgres

# Flutterwave — get these from dashboard.flutterwave.com
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — set this yourself, then paste same value in Flutterwave dashboard
FLW_WEBHOOK_SECRET=your-webhook-secret-string
