# Flask
SECRET_KEY=your-very-secret-key-change-this

# Local dev uses SQLite by default
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# MTN MoMo — get these from momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=your-collection-subscription-key
MOMO_API_USER=your-api-user-uuid
MOMO_API_KEY=your-api-key

# sandbox or production
MOMO_ENVIRONMENT=sandbox

# Use EUR in sandbox, UGX in production
MOMO_CURRENCY=EUR

# Your deployed app base URL (used for MoMo API base)
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
